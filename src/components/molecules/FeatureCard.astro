---
import type { Feature } from "@/data/features";
import { Image } from "astro:assets";

interface Props {
  data: Feature;
}

const { data } = Astro.props;
---

<div
  class="glass-effect p-2 flex flex-col gap-4 items-center text-center glass-effect-hover aspect-square min-w-52 w-52 max-w-52 rounded-lg"
>
  <Image src={data.icon} width={48} height={48} alt={data.name} />
  <h3 class="text-xl font-bold">{data.name}</h3>
  <p class="text-neutral-white-800">{data.description}</p>
</div>
