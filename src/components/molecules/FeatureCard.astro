---
import type { Feature } from "@/data/features";
import { Image } from "astro:assets";

interface Props {
  data: Feature;
}

const { data } = Astro.props;
---

<div
  class="glass-effect p-2 flex flex-col gap-2 items-center text-center glass-effect-hover aspect-square min-w-36 w-36 max-w-36 sm:min-w-44 sm:w-44 sm:max-w-44 md:min-w-52 md:w-52 md:max-w-52 rounded-lg"
>
  <Image
    src={data.icon}
    width={32}
    height={32}
    alt={data.name}
    loading="eager"
    class="sm:w-12 sm:h-12"
  />
  <h3 class="text-base sm:text-lg md:text-xl font-bold">{data.name}</h3>
  <p class="text-neutral-white-800 text-xs sm:text-sm">{data.description}</p>
</div>
